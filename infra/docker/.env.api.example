# BuildingOS API Environment Variables
# Production configuration example
# ==================================================

# Database
DATABASE_URL=postgresql://buildingos:buildingos@postgres:5432/buildingos

# Redis
REDIS_URL=redis://redis:6379

# Frontend / application URLs
WEB_ORIGIN=http://localhost:3011
APP_BASE_URL=http://localhost:3011

# S3-compatible storage (MinIO local)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=buildingos
S3_SECRET_KEY=buildingos123
S3_BUCKET=buildingos-local
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9100/buildingos-local

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info

# Sentry (optional)
SENTRY_DSN=

# Email Configuration (optional)
MAIL_PROVIDER=none
MAIL_FROM=BuildingOS <no-reply@buildingos.local>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Feature flags
FEATURE_PORTAL_RESIDENT=true
FEATURE_PAYMENTS_MVP=true

# Node
NODE_ENV=production
PORT=3000
