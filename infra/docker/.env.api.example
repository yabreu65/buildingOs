# BuildingOS API Environment Variables
# Example values for the docker compose environment
# ==================================================

# Database
DATABASE_URL=postgresql://USERNAME:PASSWORD@postgres:5432/buildingos

# Redis
REDIS_URL=redis://redis:6379

# Frontend / application URLs
WEB_ORIGIN=https://app.example.com
APP_BASE_URL=https://app.example.com

# S3-compatible storage (MinIO local)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=REPLACE_WITH_MINIO_ACCESS_KEY
S3_SECRET_KEY=REPLACE_WITH_MINIO_SECRET_KEY
S3_BUCKET=buildingos-app
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=https://assets.example.com/buildingos-app

# JWT
JWT_SECRET=REPLACE_WITH_A_64_CHARACTER_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info

# Sentry (optional)
SENTRY_DSN=

# Email Configuration (optional)
MAIL_PROVIDER=none
MAIL_FROM=BuildingOS <no-reply@example.com>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Assistant
AI_PROVIDER=none
AI_OLLAMA_URL=
AI_OLLAMA_MODEL=

# Feature flags
FEATURE_PORTAL_RESIDENT=true
FEATURE_PAYMENTS_MVP=true

# Node
NODE_ENV=production
PORT=3000
