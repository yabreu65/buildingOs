# =============================================================================
# BuildingOS - Staging Environment Example
# =============================================================================
# Copy this file to the staging VPS as:
#   /opt/pawtech/env/buildingos-staging.env
# Never commit the real file with secrets.
# =============================================================================

# --- Environment ---
APP_ENV=staging
NODE_ENV=production

# --- Service ports on the VPS host ---
API_PORT=4010
WEB_PORT=4011
POSTGRES_PORT=5434
REDIS_PORT=6381
MINIO_API_PORT=9110
MINIO_CONSOLE_PORT=9111

# --- PostgreSQL ---
POSTGRES_USER=buildingos
POSTGRES_PASSWORD=REPLACE_WITH_STAGING_POSTGRES_PASSWORD
POSTGRES_DB=buildingos_staging_db

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Web / API URLs ---
WEB_ORIGIN=https://buildingos-staging.31-220-98-21.sslip.io
APP_BASE_URL=https://buildingos-staging.31-220-98-21.sslip.io
API_URL=https://buildingos-api-staging.31-220-98-21.sslip.io

# --- JWT / Auth ---
JWT_SECRET=REPLACE_WITH_STAGING_JWT_SECRET_64_CHARS_MINIMUM
JWT_EXPIRES_IN=24h

# --- Storage / MinIO ---
MINIO_ROOT_USER=REPLACE_WITH_STAGING_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=REPLACE_WITH_STAGING_MINIO_ROOT_PASSWORD
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=buildingos-staging
S3_PUBLIC_BASE_URL=https://buildingos-staging-files.31-220-98-21.sslip.io
S3_FORCE_PATH_STYLE=true

# --- Mail / Payments ---
MAIL_PROVIDER=smtp
MAIL_FROM=BuildingOS Staging <no-reply@buildingos.local>
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAILPIT_UI_PORT=8026
PAYMENT_PROVIDER=none

# --- Assistant / AI ---
AI_PROVIDER=none
AI_OLLAMA_URL=
AI_OLLAMA_MODEL=
AI_CLASSIFIER_MODEL=

# --- Feature flags ---
FEATURE_PORTAL_RESIDENT=true
FEATURE_PAYMENTS_MVP=true

# --- Observability ---
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
