  // SUPER_ADMIN
  TENANT_CREATE
  TENANT_UPDATE
  TENANT_DELETE
  TENANT_BRANDING_UPDATED
  SUBSCRIPTION_CREATE
  SUBSCRIPTION_UPDATE
  SUBSCRIPTION_CANCEL
  SUBSCRIPTION_PAST_DUE
  USER_CREATE
  USER_DELETE
  OTHER
  // AUTH
  AUTH_LOGIN
  AUTH_LOGOUT
  AUTH_FAILED_LOGIN
  MEMBERSHIP_INVITE_SENT
  MEMBERSHIP_INVITE_ACCEPTED
  MEMBERSHIP_INVITE_REVOKED
  MEMBERSHIP_INVITE_RESENT
  MEMBERSHIP_INVITE_EXPIRED
