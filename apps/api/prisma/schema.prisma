generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantType {
  ADMINISTRADORA
  EDIFICIO_AUTOGESTION
}

enum Role {
  SUPER_ADMIN
  TENANT_OWNER
  TENANT_ADMIN
  OPERATOR
  RESIDENT
}

enum ScopeType {
  TENANT
  BUILDING
  UNIT
}

enum UnitOccupantRole {
  OWNER
  RESIDENT
}
enum MemberStatus {
  DRAFT
  PENDING_INVITE
  ACTIVE
  DISABLED
}

enum MovementType {
  EXPENSE
  INCOME
}

enum CatalogScope {
  BUILDING
  CONDOMINIUM_COMMON
}

// ============================================================================
// FINANZAS (Charges, Payments, Allocations)
// ============================================================================

enum ChargeStatus {
  PENDING
  PARTIAL
  PAID
  CANCELED
}

enum PaymentStatus {
  SUBMITTED
  APPROVED
  REJECTED
  RECONCILED
}

enum PaymentMethod {
  TRANSFER
  CASH
  CARD
  ONLINE
}

enum RejectionReason {
  MONTO_INCORRECTO
  REFERENCIA_INVALIDA
  SIN_COMPROBANTE
  COMPROBANTE_ILEGIBLE
  PAGO_DUPLICADO
  CUENTA_DESTINO_INVALIDA
  OTRO
}

enum ChargeType {
  COMMON_EXPENSE
  EXTRAORDINARY
  FINE
  CREDIT
  OTHER
}

enum ExpensePeriodStatus {
  DRAFT
  GENERATED
  PUBLISHED
  CLOSED
}

enum ExpenseStatus {
  DRAFT
  VALIDATED
  VOID
}

enum IncomeStatus {
  DRAFT
  RECORDED
  VOID
}

enum MovementScope {
  BUILDING        // Impacta directamente un edificio
  TENANT_SHARED   // Se reparte entre N edificios via allocations
  UNIT_GROUP      // Se reparte solo entre un grupo de unidades
}

enum IncomeDestination {
  APPLY_TO_EXPENSES  // Baja el neto a prorratear
  RESERVE_FUND       // Va a fondo de reserva (no afecta liquidación)
  SPECIAL_FUND       // Fase 2
}

enum LiquidationStatus {
  DRAFT
  REVIEWED
  PUBLISHED
  CANCELED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
}

enum LeadIntent {
  DEMO      // "Solicitar demo" from landing page
  CONTACT   // "Get started" from contact/signup flow
}

model Tenant {
  id                    String                 @id @default(cuid())
  name                  String                 @unique
  type                  TenantType
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Branding
  brandName             String?                // Commercial name (different from tenant name)
  logoFileId            String?                // FK to File, if uploaded
  primaryColor          String?                // Hex color: #123456
  secondaryColor        String?                // Optional secondary color
  theme                 String?                // "light" | "dark" | "system"
  emailFooter           String?                // For future email communications

  // Localization & Currency
  currency              String @default("ARS") // ARS (Argentina), VES (Venezuela), USD
  locale                String @default("es-AR") // es-AR, es-VE, en-US

  // Relations
  memberships           Membership[]
  buildings             Building[]
  auditLogs             AuditLog[]
  subscription          Subscription?
  paymentVerifications  PaymentVerification[]
  tickets               Ticket[]
  ticketComments        TicketComment[]
  communications        Communication[]
  communicationTargets  CommunicationTarget[]
  communicationReceipts CommunicationReceipt[]
  files                 File[]
  documents             Document[]
  vendors               Vendor[]
  vendorAssignments     VendorAssignment[]
  quotes                Quote[]
  workOrders            WorkOrder[]
  charges               Charge[]
  payments              Payment[]
  paymentAllocations    PaymentAllocation[]
  paymentAuditLogs      PaymentAuditLog[]    // Auditoría de pagos
  invitations           Invitation[]
  onboardingState       OnboardingState?
  emailLogs             EmailLog[]
  supportTickets        SupportTicket[]
  notifications         Notification[]
  aiInteractionLogs     AiInteractionLog[]
  dailyAiUsage          TenantDailyAiUsage[]
  aiBudget              TenantAiBudget?
  monthlyAiUsage        TenantMonthlyAiUsage[]
  aiTemplates           AiTemplate[]
  aiActionEvents        AiActionEvent[]
  planChangeRequests    PlanChangeRequest[]
  unitCategories           UnitCategory[]
  expensePeriods           ExpensePeriod[]
  expenseLedgerCategories  ExpenseLedgerCategory[]
  expenses                 Expense[]
  incomes                  Income[]
  movementAllocations      MovementAllocation[]
  unitGroups               UnitGroup[]
  liquidations             Liquidation[]
  tenantMembers         TenantMember[]
  tenantInvitations     TenantInvitation[]
  unitOccupants         UnitOccupant[]
  pushSubscriptions    PushSubscription[]
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  name                  String
  passwordHash          String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  memberships           Membership[]
  auditLogs             AuditLog[]
  ticketsCreated        Ticket[]               @relation("TicketCreatedBy")
  ticketComments        TicketComment[]        @relation("TicketCommentAuthor")
  communicationReceipts CommunicationReceipt[]
  paymentsCreated       Payment[]              @relation("PaymentCreatedBy")
  supportTicketsCreated SupportTicket[]        @relation("SupportTicketCreatedBy")
  supportTicketsAssigned SupportTicket[]       @relation("SupportTicketAssignedTo")
  supportTicketComments SupportTicketComment[] @relation("SupportTicketCommentAuthor")
  notifications         Notification[]         @relation("UserNotifications")
  aiInteractionLogs     AiInteractionLog[]
  reviewedPlanRequests  PlanChangeRequest[]    @relation("PlanRequestReviewedBy")
  tenantMembers        TenantMember[]
  pushSubscriptions PushSubscription[]
}

model Membership {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles                 MembershipRole[]
  assignedTickets       Ticket[]
  communicationsCreated Communication[]
  filesCreated          File[]
  documentsCreated      Document[]
  assignedWorkOrders    WorkOrder[]           @relation("WorkOrderAssignedTo")
  chargesCreatedBy      Charge[]
  paymentsReviewedBy    Payment[]
  paymentAuditLogs      PaymentAuditLog[]    // Auditoría de pagos
  invitationsSent       Invitation[]          @relation("InvitationsSent")
  aiInteractionLogs     AiInteractionLog[]
  aiActionEvents        AiActionEvent[]
  planChangeRequests    PlanChangeRequest[]   @relation("PlanRequestRequestedBy")

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
  userContext      UserContext?
}

model UserContext {
  id                String   @id @default(cuid())
  membershipId      String   @unique
  activeBuildingId  String?
  activeUnitId      String?
  updatedAt         DateTime @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  building   Building?  @relation("UserContextBuilding", fields: [activeBuildingId], references: [id], onDelete: SetNull)
  unit       Unit?      @relation("UserContextUnit", fields: [activeUnitId], references: [id], onDelete: SetNull)

  @@index([membershipId])
  @@index([activeBuildingId])
  @@index([activeUnitId])
}

model MembershipRole {
  id              String     @id @default(cuid())
  membershipId    String
  role            Role
  scopeType       ScopeType  @default(TENANT)
  scopeBuildingId String?
  scopeUnitId     String?

  membership    Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  scopeBuilding Building?  @relation("BuildingMembershipRoles", fields: [scopeBuildingId], references: [id], onDelete: SetNull)
  scopeUnit     Unit?      @relation("UnitMembershipRoles", fields: [scopeUnitId], references: [id], onDelete: SetNull)

  @@index([membershipId, role])
  @@index([scopeType, scopeBuildingId])
  @@index([scopeType, scopeUnitId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id                    String           @id @default(cuid())
  tenantId              String
  email                 String
  tokenHash             String           @unique
  roles                 Json // string[] of Role enum, e.g. ["OPERATOR"]
  invitedByMembershipId String
  status                InvitationStatus @default(PENDING)
  expiresAt             DateTime
  createdAt             DateTime         @default(now())
  acceptedAt            DateTime?

  tenant              Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedByMembership Membership @relation("InvitationsSent", fields: [invitedByMembershipId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email, status])
  @@index([tenantId])
  @@index([tokenHash])
  @@index([status])
}

model Building {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  address        String?
  allocationMode String   @default("MANUAL") // "MANUAL" | "BY_CATEGORY_RANGE_M2_COEFFICIENT"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant                Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  units                 Unit[]
  tickets               Ticket[]
  communications        Communication[]
  documents             Document[]
  vendorAssignments     VendorAssignment[]
  quotes                Quote[]
  workOrders            WorkOrder[]
  charges               Charge[]
  payments              Payment[]
  membershipRoles       MembershipRole[]      @relation("BuildingMembershipRoles")
  userContexts          UserContext[]         @relation("UserContextBuilding")
  unitCategories       UnitCategory[]
  expensePeriods       ExpensePeriod[]
  expenses             Expense[]
  incomes              Income[]
  movementAllocations  MovementAllocation[]
  unitGroups           UnitGroup[]
  liquidations         Liquidation[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Unit {
  id              String   @id @default(cuid())
  buildingId      String
  code            String
  label           String?
  unitType        String   @default("APARTMENT") // APARTMENT, HOUSE, OFFICE, STORAGE, PARKING
  occupancyStatus String   @default("UNKNOWN") // UNKNOWN, VACANT, OCCUPIED
  m2              Float?   // Metros cuadrados (nullable — no todos los edificios los tienen)
  isBillable      Boolean  @default(true) // false = pasillos, depósitos, excluir del prorrateo
  unitCategoryId  String?  // FK a UnitCategory (auto-asignado por el motor)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  building        Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unitCategory    UnitCategory?     @relation("UnitCategoryUnits", fields: [unitCategoryId], references: [id], onDelete: SetNull)
  unitOccupants   UnitOccupant[]
  tickets         Ticket[]
  documents       Document[]
  charges         Charge[]
  payments        Payment[]
  membershipRoles MembershipRole[]  @relation("UnitMembershipRoles")
  userContexts    UserContext[]     @relation("UserContextUnit")
  unitGroupMembers UnitGroupMember[]

  @@unique([buildingId, code])
  @@index([buildingId])
  @@index([buildingId, unitCategoryId])
}

model UnitOccupant {
  id            String           @id @default(cuid())
  tenantId      String
  unitId        String
  memberId      String
  role          UnitOccupantRole
  isPrimary     Boolean          @default(false)
  startDate     DateTime         @default(now())
  endDate       DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit     Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  member   TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([unitId, memberId])
  @@index([tenantId, memberId])
  @@index([unitId])
  @@index([unitId, isPrimary])
}

// ============================================================================
// EXPENSE ALLOCATION: Categories and Periods
// ============================================================================

model UnitCategory {
  id          String   @id @default(cuid())
  tenantId    String
  buildingId  String
  name        String
  minM2       Float
  maxM2       Float?   // null = sin límite superior (catch-all)
  coefficient Float    // Factor de prorrateo. Debe ser > 0
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  units    Unit[]   @relation("UnitCategoryUnits")

  @@unique([buildingId, name])
  @@index([tenantId, buildingId])
  @@index([buildingId, active])
}

model ExpensePeriod {
  id              String                @id @default(cuid())
  tenantId        String
  buildingId      String
  year            Int
  month           Int
  totalToAllocate BigInt                // En centavos (ej: 1500000 = $15,000)
  currency        String                @default("ARS")
  dueDate         DateTime
  concept         String                // Ej: "Expensas Comunes - Enero 2026"
  status          ExpensePeriodStatus   @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  charges  Charge[]

  @@unique([buildingId, year, month]) // Un período por mes por edificio
  @@index([tenantId, buildingId])
  @@index([tenantId, status])
}

// ============================================================================
// AUDIT LOGGING (OPCIÓN A — SUPER_ADMIN Backend)
// ============================================================================

